# ==== BLOCKCHAIN API KEYS ====
# Thay THE_ALCHEMY_API_KEY bằng key của bạn (dùng cho AsyncHTTPProvider của Web3.py)
ALCHEMY_API_KEY=THE_ALCHEMY_API_KEY
# Thay THE_ETHERSCAN_API_KEY bằng key thật để tra cứu mã nguồn / ABI smart contract nếu cần
ETHERSCAN_API_KEY=THE_ETHERSCAN_API_KEY
# RPC URL sử dụng Alchemy
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ==== AI CONNECTOR API KEYS ====
# API key cho mô hình Groq (Llama-3-70B)
GROQ_API_KEY=your_groq_api_key_here
# API key fallback cho Gemini Flash 1.5
GEMINI_API_KEY=your_gemini_api_key_here

# ==== DATABASE CONFIGURATION (POSTGRESQL) ====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=crypto_risk
# Link kết nối CSDL (Dành cho SQLAlchemy / asyncpg / docker)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ==== CACHING CONFIGURATION (REDIS) ====
REDIS_URL=redis://localhost:6379/0
